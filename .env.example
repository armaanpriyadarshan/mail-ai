# Mail AI client env. Only EXPO_PUBLIC_* vars are exposed to the app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id
EXPO_PUBLIC_EXPO_USERNAME=your-expo-account-username

# Server-side secrets (set in Supabase dashboard, NOT in this file):
#   GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET
#   APOLLO_API_KEY
#   OPENAI_API_KEY
#   STRIPE_SECRET_KEY
#   STRIPE_WEBHOOK_SECRET
#   STRIPE_PRO_PRICE_ID
